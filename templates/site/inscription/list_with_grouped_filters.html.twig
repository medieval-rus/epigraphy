{%- extends 'site/base.html.twig' -%}

{%- block stylesheets -%}
    {{ parent() }}
    <style>
        main.eomr-main table[data-vyfony-filterable-table] tbody tr {
            cursor: pointer;
        }

        main.eomr-main table[data-vyfony-filterable-table] tbody tr > th,
        main.eomr-main table[data-vyfony-filterable-table] tbody tr > td {
            transition: background-color 0.15s ease-in-out;
        }

        @media (hover: hover) and (pointer: fine) {
            main.eomr-main table[data-vyfony-filterable-table] tbody tr:hover > th,
            main.eomr-main table[data-vyfony-filterable-table] tbody tr:hover > td {
                background-color: #e9ecef !important;
            }
        }

        main.eomr-main table[data-vyfony-filterable-table] tbody tr:focus-visible {
            outline: 2px solid #6c757d;
            outline-offset: -2px;
        }

        main.eomr-main table[data-vyfony-filterable-table] a.table-filter-link {
            color: #495057;
            text-decoration: underline;
            text-decoration-thickness: 1px;
            text-underline-offset: 2px;
            transition: color 0.15s ease-in-out, background-color 0.15s ease-in-out;
        }

        main.eomr-main table[data-vyfony-filterable-table] a.table-filter-link:hover,
        main.eomr-main table[data-vyfony-filterable-table] a.table-filter-link:focus-visible {
            color: #212529;
            background-color: #dde2e6;
            border-radius: 2px;
            outline: none;
            text-decoration: none;
        }
    </style>
{%- endblock -%}

{%- block page_content -%}

    {% import '@VyfonyFilterableTable/filterable_table.html.twig' as filterable_table %}
    {% import 'site/content/post.html.twig' as post_helper %}

    <div style='z-index: 0; position: absolute; right: 1.5rem; top: 1px;'>
    <a class="btn btn-secondary" data-toggle="tooltip" data-placement="top" title="Поиск с учетом лексемы и морфологических признаков." target="_blank" href="https://ruscorpora.ru/search?search=CgQyAggXMAE%3D">
        Поиск в НКРЯ
    </a>    
    </div>

    <div class="list_with_grouped_filters">
        {{ _self.render_grouped_filter(filterForm, filterConfigurator) }}
    </div>

    <div class="row">
        <div class="col-12 inscription-search-table-col">
            {{ filterable_table.render_table(table) }}
            {# {{ dump(table) }} #}
        </div>
    </div>

    <div class="row">
        {{ filterable_table.render_paginator(table) }}
    </div>

    <div class="row">
        {{ filterable_table.render_checkbox_handlers(table) }}
    </div>
{%- endblock -%}

{%- block page_title -%}
    <div class="container pb-2">
        <h1 class="border-bottom">{{ block('title') }}</h1>
    </div>
{%- endblock -%}

{%- block javascripts -%}
    {{ parent() }}
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const table = document.querySelector('table[data-vyfony-filterable-table]');
            if (!table) {
                return;
            }

            const interactiveSelector = 'a, button, input, textarea, select, label, summary, [role="button"]';

            table.addEventListener('click', function (event) {
                const row = event.target.closest('tbody tr[data-row-href]');
                if (!row) {
                    return;
                }

                if (event.target.closest(interactiveSelector)) {
                    return;
                }

                const href = row.getAttribute('data-row-href');
                if (href) {
                    event.preventDefault();
                    event.stopImmediatePropagation();
                    window.location.href = href;
                }
            }, true);
        });
    </script>
{%- endblock -%}

{%- macro render_grouped_filter(filterForm, filterConfigurator) -%}
    {% import _self as self %}
    {% form_theme filterForm '@VyfonyFilterableTable/filterable_table_form_layout.html.twig' %}
    
    <form method="{{ filterForm.vars.method }}" action="{{ filterForm.vars.action }}" class="{{ filterForm.vars.attr.class|default('') }}"{% if filterForm.vars.multipart %} enctype="multipart/form-data"{% endif %}>
        <div class="row">
            <!-- Grouped filters (collapsible sections) -->
            {% set groupedFilters = filterConfigurator.getGroupedFilterParameters() %}
            
            {% for groupKey, group in groupedFilters %}
                <div class="col-12 mb-4 filter-section">
                    <div class="card">
                        <div class="card-header" data-toggle="collapse" data-target="#filter-group-{{ groupKey }}" aria-expanded="true" aria-controls="filter-group-{{ groupKey }}" style="cursor: pointer;">
                            <h5 class="mb-0">
                                <i class="fas fa-chevron-down collapse-icon" id="icon-{{ groupKey }}"></i>
                                {{ group.label|trans }}
                            </h5>
                        </div>
                        <div class="collapse show" id="filter-group-{{ groupKey }}">
                            <div class="card-body">
                                {% for row in group.rows %}
                                    <div class="row filter-row mb-3">
                                        {% for filterParameter in row %}
                                            {% set fieldName = filterParameter.getQueryParameterName() %}
                                            {% if filterForm[fieldName] is defined %}
                                                {% if fieldName in ['conventionalDateInitialYear', 'conventionalDateFinalYear'] %}
                                                    {# skip rendering here; handled by the custom slider block below #}
                                                {% else %}
                                                    <div class="col-md-6">
                                                        {{ form_row(filterForm[fieldName]) }}
                                                    </div>
                                                {% endif %}
                                            {% endif %}
                                        {% endfor %}
                                    </div>
                                {% endfor %}
                                
                                {# Date range slider - now wired to hidden form fields #}
                                {% if groupKey == 'inscriptionData' %}
                                    <div class="row filter-row mb-3">
                                        <div class="col-12">
                                            <div class="form-group">
                                                <label class="control-label">
                                                    Датировка
                                                </label>
                                                <div
                                                    id="conventional-date-range-slider"
                                                    data-minimal-date="862"
                                                    data-maximal-date="1700"
                                                ></div>
                                                <div class="row mt-2 align-items-end">
                                                    <div class="col-4">
                                                        <label class="form-label small">От года:</label>
                                                        <input type="number" class="form-control" id="conventional-date-initial-input" placeholder="Начальный год">
                                                    </div>
                                                    <div class="col-4">
                                                        <label class="form-label small">До года:</label>
                                                        <input type="number" class="form-control" id="conventional-date-final-input" placeholder="Конечный год">
                                                    </div>
                                                    <div class="col-4">
                                                        <div class="form-check date-exact-match-checkbox">
                                                            <input type="checkbox" class="form-check-input" id="conventional-date-exact-match" name="conventionalDateExactMatch" value="1">
                                                            <label class="form-check-label" for="conventional-date-exact-match">
                                                                Строгое вхождение
                                                            </label>
                                                        </div>
                                                    </div>
                                                </div>
                                                {# Ensure hidden fields exist in the form so values submit #}
                                                {% if filterForm['conventionalDateInitialYear'] is defined %}
                                                    {{ form_widget(filterForm['conventionalDateInitialYear']) }}
                                                {% else %}
                                                    <input type="hidden" id="conventionalDateInitialYear" name="conventionalDateInitialYear" />
                                                {% endif %}

                                                {% if filterForm['conventionalDateFinalYear'] is defined %}
                                                    {{ form_widget(filterForm['conventionalDateFinalYear']) }}
                                                {% else %}
                                                    <input type="hidden" id="conventionalDateFinalYear" name="conventionalDateFinalYear" />
                                                {% endif %}
                                            </div>
                                        </div>
                                    </div>
                                {% endif %}
                            </div>
                        </div>
                    </div>
                </div>
            {% endfor %}
            
            <!-- Standalone filters (always visible) -->
            {% set standaloneFilters = filterConfigurator.getStandaloneFilterParameters() %}
            {% for filterParameter in standaloneFilters %}
                {% set fieldName = filterParameter.getQueryParameterName() %}
                {% if filterForm[fieldName] is defined %}
                    <div class="col-12 mb-4">
                        <div class="standalone-filter-field">
                            {{ form_row(filterForm[fieldName]) }}
                        </div>
                    </div>
                {% endif %}
            {% endfor %}
            
            <!-- Action buttons -->
            <div class="col-12">
                <div class="form-group vyfony-filterable-table-bundle-button-form-group">
                    {% for child in filterForm.children %}
                        {% if child.vars.block_prefixes[1] == 'submit' or child.vars.block_prefixes[1] == 'button' %}
                            {{ form_widget(child) }}
                        {% endif %}
                    {% endfor %}
                </div>
            </div>
        </div>
        {{ form_rest(filterForm) }}
    </form>

    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Handle collapse toggle
            document.querySelectorAll('[data-toggle="collapse"]').forEach(function(element) {
                element.addEventListener('click', function() {
                    const target = document.querySelector(this.getAttribute('data-target'));
                    const icon = document.getElementById(this.getAttribute('data-target').replace('#filter-group-', '#icon-'));
                    
                    if (target.classList.contains('show')) {
                        icon.classList.remove('fa-chevron-down');
                        icon.classList.add('fa-chevron-right');
                    } else {
                        icon.classList.remove('fa-chevron-right');
                        icon.classList.add('fa-chevron-down');
                    }
                });
            });
            
            // Handle the exact match checkbox - restore state from URL
            const exactMatchCheckbox = document.getElementById('conventional-date-exact-match');
            if (exactMatchCheckbox) {
                // Initialize checkbox state from URL parameters
                const urlParams = new URLSearchParams(window.location.search);
                const exactMatchValue = urlParams.get('conventionalDateExactMatch');
                if (exactMatchValue === '1') {
                    exactMatchCheckbox.checked = true;
                }
            }
            
            // Handle Enter key in fulltext search field (CKEditor)
            // Wait for CKEditor to be loaded
            if (typeof CKEDITOR !== 'undefined') {
                // Listen for all CKEditor instances
                CKEDITOR.on('instanceReady', function(evt) {
                    var editor = evt.editor;
                    
                    // Check if this is the fulltext editor
                    if (editor.name && editor.name.includes('fulltext')) {
                        // Configure enterMode to prevent automatic paragraph/br insertion
                        editor.on('key', function(e) {
                            if (e.data.keyCode === 13) { // Enter key
                                if (!e.data.domEvent.$.shiftKey) {
                                    // Prevent default Enter behavior
                                    e.cancel();
                                    // Submit the form
                                    var form = editor.element.$.form;
                                    if (form) {
                                        form.submit();
                                    }
                                    return false;
                                }
                                // Shift+Enter will allow default behavior (new line)
                            }
                        });
                    }
                });
            }
        });
    </script>
{%- endmacro -%}
