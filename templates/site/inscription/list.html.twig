{%- extends 'site/base.html.twig' -%}

{%- block stylesheets -%}
    {{ parent() }}
    <style>
        main.eomr-main table[data-vyfony-filterable-table] .table-primary-cell {
            align-items: center;
            display: flex;
            gap: 0.5rem;
            white-space: nowrap;
        }

        main.eomr-main table[data-vyfony-filterable-table] a.table-primary-link {
            color: #0b4ea2;
            font-weight: 600;
            text-decoration: none;
        }

        main.eomr-main table[data-vyfony-filterable-table] a.table-primary-link:hover,
        main.eomr-main table[data-vyfony-filterable-table] a.table-primary-link:focus-visible {
            text-decoration: underline;
            text-decoration-thickness: 1px;
            text-underline-offset: 2px;
        }

        main.eomr-main table[data-vyfony-filterable-table] .table-filter-chip-list {
            display: inline-flex;
            flex-wrap: wrap;
            gap: 0.25rem;
            vertical-align: middle;
        }

        main.eomr-main table[data-vyfony-filterable-table] a.table-filter-link {
            color: #495057;
            line-height: 1.25;
            text-decoration: none;
            transition: color 0.15s ease-in-out, text-decoration-color 0.15s ease-in-out;
        }

        main.eomr-main table[data-vyfony-filterable-table] a.table-filter-link:hover,
        main.eomr-main table[data-vyfony-filterable-table] a.table-filter-link:focus-visible {
            color: #0b3d91;
            outline: none;
            text-decoration: underline;
            text-decoration-thickness: 1px;
            text-underline-offset: 2px;
        }
    </style>
{%- endblock -%}

{%- block page_content -%}

    {% import '@VyfonyFilterableTable/filterable_table.html.twig' as filterable_table %}
    {% import 'site/content/post.html.twig' as post_helper %}

    {% form_theme filterForm '@VyfonyFilterableTable/filterable_table_form_layout.html.twig' %}
    {{ form_start(filterForm) }}
    {% for child in filterForm %}
        {% if child.vars.block_prefixes[1] != 'submit' and child.vars.block_prefixes[1] != 'button' %}
            {{ form_row(child) }}
        {% endif %}
    {% endfor %}
    <div class="form-group vyfony-filterable-table-bundle-button-form-group d-flex align-items-center" style="gap: 0.5rem;">
        {% for child in filterForm %}
            {% if child.vars.block_prefixes[1] == 'submit' or child.vars.block_prefixes[1] == 'button' %}
                {{ form_widget(child) }}
            {% endif %}
        {% endfor %}
        <a class="btn btn-outline-secondary"
           data-toggle="tooltip"
           data-placement="top"
           title="Поиск с учетом лексемы и морфологических признаков."
           target="_blank"
           href="https://ruscorpora.ru/search?search=CgQyAggXMAE%3D">
            {{ 'controller.inscription.list.filter.searchInRuscorporaButton'|trans }}
        </a>
    </div>
    {{ form_end(filterForm) }}

    <div class="row">
        <div class="col-12 inscription-search-table-col">
            <p class="text-muted small mb-2">
                {{ 'controller.inscription.list.table.hint'|trans }}
            </p>
            {{ filterable_table.render_table(table) }}
            {# {{ dump(table) }} #}
        </div>
    </div>

    <div class="row">
        {{ filterable_table.render_paginator(table) }}
    </div>

    <div class="row">
        {{ filterable_table.render_checkbox_handlers(table) }}
    </div>
{%- endblock -%}

{%- block page_title -%}
    <div class="container pb-2">
        <h1 class="border-bottom">{{ block('title') }}</h1>
    </div>
{%- endblock -%}

{%- block javascripts -%}
    {{ parent() }}
{%- endblock -%}
